# --- App Web (Next.js) — variaveis de ambiente --------------------------------
# Copie para .env.local e preencha. .env.local NUNCA vai para o git.
#
# Pegue os valores em: Supabase Dashboard > Project Settings > API

# URL do projeto Supabase (ex: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=""

# Chave publica "anon" (pode ir para o client; protegida pela RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# (Sprint 2+) Chave service_role — ignora RLS. NUNCA expor no client,
# usar apenas em codigo de servidor / Edge Functions.
# SUPABASE_SERVICE_ROLE_KEY=""
